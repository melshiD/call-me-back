PORT=8001

# Speech-to-text (Deepgram Flux)
DEEPGRAM_API_KEY=

# Text-to-speech (ElevenLabs)
ELEVENLABS_API_KEY=

# Legacy inference provider (being removed in Phase B)
CEREBRAS_API_KEY=

# Legacy Raindrop-era DB-proxy URL. Intercepted by the DB-SHIM at the top of
# index.js and routed through direct pg calls against DATABASE_URL.
# See README.md "DB-SHIM" section.
VULTR_DB_API_URL=https://api.callbackapp.ai
VULTR_DB_API_KEY=

# Raindrop-era API gateway URL (legacy). Not used by the current api-server.
API_GATEWAY_URL=

# Admin token for privileged cross-service calls
ADMIN_SECRET_TOKEN=

# Direct Postgres connection for DB-SHIM
DATABASE_URL=postgres://user:pass@host:5432/call_me_back

# OpenAI (current chat model: gpt-4o-mini — pending Phase B inference routing)
OPENAI_API_KEY=
