# =============================================================================
# Secrets to set on the VPS
# =============================================================================
#
# 1. Copy this file:  cp set-secrets.template /tmp/secrets.conf
# 2. Edit it:         nano /tmp/secrets.conf
# 3. Paste your real values below (replace the placeholders)
# 4. Run:             ./set-secrets.sh /tmp/secrets.conf
# 5. The file will be shredded after use
#
# Lines starting with # are ignored. Empty values are skipped.
# Only uncomment and fill in the ones you need to set.
# =============================================================================

# Twilio Verify (get from Twilio Console > Verify > Services)
TWILIO_VERIFY_SERVICE_SID=

# Stripe (get from Stripe Dashboard > Developers > API keys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Anthropic (get from console.anthropic.com > API Keys)
ANTHROPIC_API_KEY=

# OpenAI (get from platform.openai.com > API Keys)
OPENAI_API_KEY=
